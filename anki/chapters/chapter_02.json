    {
      "th": "หนึ่ง สอง สาม",
      "cz": "Jedna, dva, tři.",
      "sk": "Jeden, dva, tri.",
      "czph": "nung sóng sám"
    },
    {
      "th": "อายุเท่าไหร่ครับ",
      "cz": "Kolik je vám let?",
      "sk": "Koľko máte rokov?",
      "czph": "á ju thao raj khrap"
    },
    {
      "th": "ผมอายุยี่สิบปี",
      "cz": "Je mi dvacet let.",
      "sk": "Mám dvadsať rokov.",
      "czph": "phom á ju jí sip pí"
    },
    {
      "th": "มีห้า",
      "cz": "Je jich pět.",
      "sk": "Je ich päť.",
      "czph": "mí há"
    },
    {
      "th": "มีสิบสอง",
      "cz": "Je jich dvanáct.",
      "sk": "Je ich dvanásť.",
      "czph": "mí sip sóng"
    },
    {
      "th": "เขาอายุสิบแปดปี",
      "cz": "Je mu osmnáct let.",
      "sk": "Má osemnásť rokov.",
      "czph": "khau á ju sip paét pí"
    },
    {
      "th": "มีเท่าไหร่",
      "cz": "Kolik toho je?",
      "sk": "Koľko toho je?",
      "czph": "mí thao raj"
    },
    {
      "th": "ผมมีสาม",
      "cz": "Mám tři.",
      "sk": "Mám tri.",
      "czph": "phom mí sám"
    },
    {
      "th": "คุณมีสิบ",
      "cz": "Máte deset.",
      "sk": "Máte desať.",
      "czph": "khun mí sip"
    },
    {
      "th": "เขาอายุเก้าปี",
      "cz": "Je mu devět let.",
      "sk": "Má deväť rokov.",
      "czph": "khau á ju kau pí"
    }
  ]
