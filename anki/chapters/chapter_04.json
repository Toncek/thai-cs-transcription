      "cz": "Mám staršího bratra.",
      "sk": "Mám staršieho brata.",
      "czph": "phommíphíčáj"
    },
    {
      "th": "เขามีน้องสาว",
      "cz": "On má mladší sestru.",
      "sk": "On má mladšiu sestru.",
      "czph": "khaomínóngsáu"
    },
    {
      "th": "พ่อรักแม่",
      "cz": "Otec miluje matku.",
