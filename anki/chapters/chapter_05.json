  "sentences": [
    {
      "th": "ฉันหิวข้าว",
      "cz": "Mám hlad.",
      "sk": "Som hladný.",
      "czph": "čanhiukháu"
    },
    {
      "th": "อาหารอร่อยมาก",
      "cz": "Jídlo je velmi chutné.",
      "sk": "Jedlo je veľmi chutné.",
      "czph": "áhánarójmák"
    },
    {
      "th": "ผมไม่กินเผ็ด",
      "cz": "Nejím pálivé.",
      "sk": "Nejem pikantné.",
      "czph": "phommajkinphet"
    },
    {
      "th": "ขอน้ำครับ",
      "cz": "Prosím vodu.",
      "sk": "Prosím vodu.",
      "czph": "khónamkrap"
    },
    {
      "th": "ฉันชอบผลไม้",
      "cz": "Mám ráda ovoce.",
      "sk": "Mám rada ovocie.",
      "czph": "čančópphonmaj"
    },
    {
      "th": "กาแฟร้อน",
      "cz": "Horká káva.",
      "sk": "Horúca káva.",
      "czph": "káférón"
    },
    {
      "th": "กินข้าวกับไก่",
      "cz": "Jíst rýži s kuřecím.",
      "sk": "Jesť ryžu s kuracím.",
      "czph": "kinkháukapkaj"
    },
    {
      "th": "ปลาอร่อยไหม",
      "cz": "Je ryba dobrá?",
      "sk": "Je ryba dobrá?",
      "czph": "pláórójmaj"
    },
    {
      "th": "ผมอิ่มแล้ว",
      "cz": "Jsem plný.",
      "sk": "Som plný.",
      "czph": "phomimléu"
    },
    {
      "th": "ไปร้านอาหาร",
      "cz": "Jít do restaurace.",
      "sk": "Ísť do reštaurácie.",
      "czph": "pajránáhán"
    }
  ]
