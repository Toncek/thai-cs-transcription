  "sentences": [
    {
      "th": "วันนี้วันจันทร์",
      "cz": "Dnes je pondělí.",
      "sk": "Dnes je pondelok.",
      "czph": "van ný van džan"
    },
    {
      "th": "พรุ่งนี้วันอังคาร",
      "cz": "Zítra je úterý.",
      "sk": "Zajtra je utorok.",
      "czph": "phrung ný van anghán"
    },
    {
      "th": "ตอนเช้า",
      "cz": "Ráno.",
      "sk": "Ráno.",
      "czph": "tón čao"
    },
    {
      "th": "เจอกันตอนบ่าย",
      "cz": "Uvidíme se odpoledne.",
      "sk": "Uvidíme sa poobede.",
      "czph": "džéó kan tón báj"
    },
    {
      "th": "เมื่อวานสนุกมาก",
      "cz": "Včera to byla zábava.",
      "sk": "Včera to bola zábava.",
      "czph": "múa ván sanuk mák"
    },
    {
      "th": "ตอนนี้เวลาเท่าไหร่",
      "cz": "Kolik je teď hodin?",
      "sk": "Koľko je teraz hodín?",
      "czph": "tón ný velá thao raj"
    },
    {
      "th": "สามชั่วโมง",
      "cz": "Tři hodiny.",
      "sk": "Tri hodiny.",
      "czph": "sám čúa móng"
    },
    {
      "th": "เจอกันวันศุกร์",
      "cz": "Uvidíme se v pátek.",
      "sk": "Uvidíme sa v piatok.",
      "czph": "džéó kan van suk"
    },
    {
      "th": "ตอนเย็นกินข้าว",
      "cz": "Večer jím jídlo.",
      "sk": "Večer jem jedlo.",
      "czph": "tón jen kin kháu"
    },
    {
      "th": "เดือนนี้",
      "cz": "Tento měsíc.",
      "sk": "Tento mesiac.",
      "czph": "dúan ný"
