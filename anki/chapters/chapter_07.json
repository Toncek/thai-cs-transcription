  "sentences": [
    {
      "th": "รถไฟไปที่ไหน",
      "cz": "Kam jede vlak?",
      "sk": "Kam ide vlak?",
      "czph": "rot faj paj thí naj"
    },
    {
      "th": "สนามบินอยู่ไกลไหม",
      "cz": "Je letiště daleko?",
      "sk": "Je letisko ďaleko?",
      "czph": "sanám bin jú klaj maj"
    },
    {
      "th": "สถานีอยู่ใกล้",
      "cz": "Stanice je blízko.",
      "sk": "Stanica je blízko.",
      "czph": "sathá ný jú klaj (vyslov klesající tón)"
    },
    {
      "th": "เลี้ยวซ้าย",
      "cz": "Zahněte doleva.",
      "sk": "Odbočte doľava.",
      "czph": "lyau sáj"
    },
    {
      "th": "เลี้ยวขวา",
      "cz": "Zahněte doprava.",
      "sk": "Odbočte doprava.",
      "czph": "lyau kháu"
    },
    {
      "th": "เดินตรงไป",
      "cz": "Jděte rovně.",
      "sk": "Choďte rovno.",
      "czph": "dön trong paj"
    },
    {
      "th": "ผมขับรถ",
      "cz": "Řídím auto.",
      "sk": "Šoférujem auto.",
      "czph": "phom khap rot"
    },
    {
      "th": "แท็กซี่มาแล้ว",
      "cz": "Taxík už přijel.",
      "sk": "Taxík už prišiel.",
      "czph": "thek sí má léu"
    },
    {
      "th": "จอดที่นี่ครับ",
      "cz": "Zastavte tady, prosím.",
      "sk": "Zastavte tu, prosím.",
      "czph": "džót thí ný khrap"
    },
    {
      "th": "ไปรถเมล์",
      "cz": "Jet autobusem.",
      "sk": "Ísť autobusom.",
      "czph": "paj rot mé"
    }
  ]
