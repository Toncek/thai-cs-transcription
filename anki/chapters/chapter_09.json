    {
      "th": "ราคาเท่าไหร่ครับ",
      "cz": "Kolik to stojí?",
      "sk": "Koľko to stojí?",
      "czph": "rákháthaorajkrap"
    },
    {
      "th": "แพงมาก",
      "cz": "Velmi drahé.",
      "sk": "Veľmi drahé.",
      "czph": "phéngmák"
    },
    {
      "th": "ลดราคาได้ไหม",
      "cz": "Můžete dát slevu?",
      "sk": "Môžete dať zľavu?",
      "czph": "lotrákhádajmaj"
    },
    {
      "th": "อันนี้ถูก",
      "cz": "Tohle je levné.",
      "sk": "Toto je lacné.",
      "czph": "annýthúk"
    },
    {
      "th": "ฉันอยากได้กระเป๋า",
      "cz": "Chci tašku.",
      "sk": "Chcem tašku.",
      "czph": "čanjákdajkrapao"
    },
    {
      "th": "ซื้อเสื้อผ้าที่ตลาด",
      "cz": "Kupovat oblečení na trhu.",
      "sk": "Kupovať oblečenie na trhu.",
      "czph": "süsúapháthítlát"
    },
    {
      "th": "รองเท้าสวย",
      "cz": "Krásné boty.",
      "sk": "Krásne topánky.",
      "czph": "róngthaotvoj"
    },
    {
      "th": "จ่ายเงินที่ไหน",
      "cz": "Kde mohu zaplatit?",
      "sk": "Kde môžem zaplatiť?",
      "czph": "džájgönthínaj"
    },
    {
      "th": "มีเงินร้อยบาท",
      "cz": "Mám sto bahtů.",
      "sk": "Mám sto bahtov.",
      "czph": "mígönrójbát"
    },
    {
      "th": "ขายดีไหม",
      "cz": "Prodává se to dobře?",
      "sk": "Predáva sa to dobre?",
      "czph": "khájdýmaj"
