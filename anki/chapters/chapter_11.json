  "sentences": [
    {
      "th": "บ้านหลังนี้ใหญ่",
      "cz": "Tento dům je velký.",
      "sk": "Tento dom je veľký.",
      "czph": "bán lang ný jaj"
    },
    {
      "th": "เขาอยู่ในห้อง",
      "cz": "On je v pokoji.",
      "sk": "On je v izbe.",
      "czph": "khau jú naj hóng"
    },
    {
      "th": "เปิดประตูครับ",
      "cz": "Otevřete dveře, prosím.",
      "sk": "Otvorte dvere, prosím.",
      "czph": "pöt pona tú khrap"
    },
    {
      "th": "ปิดหน้าต่างค่ะ",
      "cz": "Zavřete okno.",
      "sk": "Zatvorte okno.",
      "czph": "pit nátáng kha"
    },
    {
      "th": "โต๊ะอยู่บนพื้น",
      "cz": "Stůl je na podlaze.",
      "sk": "Stôl je na podlahe.",
      "czph": "to jú bon phún"
    },
    {
      "th": "เก้าอี้อยู่ใกล้โต๊ะ",
      "cz": "Židle je blízko stolu.",
      "sk": "Stolička je blízko stola.",
      "czph": "kau í jú klaj (vyslov klesající tón) to"
    },
    {
      "th": "ห้องนี้สะอาด",
      "cz": "Tento pokoj je čistý.",
      "sk": "Táto izba je čistá.",
      "czph": "hóng ný sa át"
    },
    {
      "th": "ฉันอยากได้เตียง",
      "cz": "Chci postel.",
      "sk": "Chcem posteľ.",
      "czph": "čan ják daj týjang"
    },
    {
      "th": "มีตู้ในห้อง",
      "cz": "V pokoji je skříň.",
      "sk": "V izbe je skriňa.",
      "czph": "mí tú naj hóng"
    },
    {
      "th": "โซฟาสีแดง",
      "cz": "Červená pohovka.",
      "sk": "Červená pohovka.",
      "czph": "sófá sí déng"
    }
  ]
