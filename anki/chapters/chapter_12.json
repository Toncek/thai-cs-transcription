  "sentences": [
    {
      "th": "แม่ล้างจานในห้องครัว",
      "cz": "Matka myje nádobí v kuchyni.",
      "sk": "Matka umýva riad v kuchyni.",
      "czph": "mé láng džán naj hóng khrúa"
    },
    {
      "th": "ผมอาบน้ำในห้องน้ำ",
      "cz": "Sprchuji se v koupelně.",
      "sk": "Sprchujem sa v kúpeľni.",
      "czph": "phom áp nam naj hóng nam"
    },
    {
      "th": "ขอแก้วน้ำครับ",
      "cz": "Prosím sklenici vody.",
      "sk": "Prosím pohár vody.",
      "czph": "khó kaéu nam khrap"
    },
    {
      "th": "ช้อนและส้อม",
      "cz": "Lžíce a vidlička.",
      "sk": "Lyžica a vidlička.",
      "czph": "čón le sóm"
    },
    {
      "th": "ห้องน้ำสกปรก",
      "cz": "Koupelna je špinavá.",
      "sk": "Kúpeľňa je špinavá.",
      "czph": "hóng nam sok kaprok"
    },
    {
      "th": "ฉันทำความสะอาดบ้าน",
      "cz": "Uklízím dům.",
      "sk": "Upratujem dom.",
      "czph": "čan tham khuaám sa át bán"
    },
    {
      "th": "ตู้เย็นเปิดอยู่",
      "cz": "Lednička je otevřená.",
      "sk": "Chladnička je otvorená.",
      "czph": "tú jen pöt jú"
    },
    {
      "th": "สบู่อยู่ที่ไหน",
      "cz": "Kde je mýdlo?",
      "sk": "Kde je mydlo?",
      "czph": "sabú jú thí naj"
    },
    {
      "th": "เขาแปรงฟันตอนเช้า",
      "cz": "Ráno si čistí zuby.",
      "sk": "Ráno si čistí zuby.",
      "czph": "khau préng fan tón čao"
    },
