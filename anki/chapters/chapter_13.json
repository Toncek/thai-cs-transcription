  "sentences": [
    {
      "th": "ฉันชอบกล้วย",
      "cz": "Mám rád banán.",
      "sk": "Mám rád banán.",
      "czph": "čan čóp kluaj"
    },
    {
      "th": "มะม่วงอร่อยมาก",
      "cz": "Mango je velmi chutné.",
      "sk": "Mango je veľmi chutné.",
      "czph": "mamuang arój mák"
    },
    {
      "th": "ซื้อส้มสองโล",
      "cz": "Koupit dvě kila pomerančů.",
      "sk": "Kúpiť dve kilá pomarančov.",
      "czph": "sú som sóng ló"
    },
    {
      "th": "แตงโมลูกใหญ่",
      "cz": "Velký meloun.",
      "sk": "Veľký melón.",
      "czph": "téngmó lúk jaj"
    },
    {
      "th": "สับปะรดเปรี้ยว",
      "cz": "Ananas je kyselý.",
      "sk": "Ananás je kyslý.",
      "czph": "sapparot pryjao"
    },
    {
      "th": "แครอทและมะเขือเทศ",
      "cz": "Mrkev a rajče.",
      "sk": "Mrkva a paradajka.",
      "czph": "khérót le makhúa thét"
    },
    {
      "th": "ผักสดดีไหม",
      "cz": "Je ta zelenina čerstvá?",
