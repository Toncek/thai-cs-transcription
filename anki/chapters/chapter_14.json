    {
      "th": "ขอเมนูครับ",
      "cz": "Prosím, jídelní lístek.",
      "sk": "Prosím si jedálny lístok.",
      "czph": "khó ménú khrap"
    },
    {
      "th": "ผมเอาข้าวผัด",
      "cz": "Dám si smaženou rýži.",
      "sk": "Dám si vyprážanú ryžu.",
      "czph": "phom ao kháu phat"
    },
    {
      "th": "ขอไม่เผ็ดนะคะ",
      "cz": "Prosím nepálivé.",
      "sk": "Prosím nepikantné.",
      "czph": "khó maj phet na kha"
    },
    {
      "th": "ไม่เอาผักครับ",
      "cz": "Nechci zeleninu.",
      "sk": "Nechcem zeleninu.",
      "czph": "maj ao phak khrap"
    },
    {
      "th": "ใส่น้ำแข็งไหม",
      "cz": "Dáte si s ledem?",
      "sk": "Dáte si s ľadom?",
      "czph": "saj nam khéng maj"
    },
    {
      "th": "ขอน้ำหนึ่งขวด",
      "cz": "Prosím jednu láhev vody.",
      "sk": "Prosím jednu fľašu vody.",
      "czph": "khó nam nung khúat"
    },
    {
      "th": "รอสักครู่ครับ",
      "cz": "Počkejte chvíli, prosím.",
      "sk": "Počkajte chvíľu, prosím.",
      "czph": "ró sak khún khrap"
    },
    {
      "th": "เช็คบิลด้วยค่ะ",
      "cz": "Účet, prosím.",
      "sk": "Účet, prosím.",
      "czph": "čék bin dúaj kha"
    },
    {
      "th": "ทั้งหมดเท่าไหร่",
      "cz": "Kolik to je celkem?",
      "sk": "Koľko to je celkom?",
      "czph": "thang mot thao raj"
    },
    {
      "th": "โต๊ะว่างไหม",
      "cz": "Je ten stůl volný?",
      "sk": "Je ten stôl voľný?",
      "czph": "to váng maj"
    }
