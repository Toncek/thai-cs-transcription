  "sentences": [
    {
      "th": "บ้านของฉันสะอาด",
      "cz": "Můj dům je čistý.",
      "sk": "Môj dom je čistý.",
      "czph": "bán khóng čan sa át"
    },
    {
      "th": "สั่งอาหารในห้องครัว",
      "cz": "Objednat jídlo v kuchyni.",
      "sk": "Objednať jedlo v kuchyni.",
      "czph": "sang á hán naj hóng khrúa"
    },
    {
      "th": "ขอแอปเปิ้ลสองลูก",
      "cz": "Prosím dvě jablka.",
      "sk": "Prosím dve jablká.",
      "czph": "khó ép pön sóng lúk"
    },
    {
      "th": "ผมอยากได้กล้วยสด",
      "cz": "Chci čerstvé banány.",
      "sk": "Chcem čerstvé banány.",
      "czph": "phom ják daj kluaj sot"
    },
    {
      "th": "แม่ทำความสะอาดห้องน้ำ",
      "cz": "Matka uklízí koupelnu.",
      "sk": "Matka upratuje kúpeľňu.",
      "czph": "mé tham khuaám sa át hóng nam"
    },
    {
      "th": "ไม่เอาผักครับ",
      "cz": "Nechci zeleninu.",
      "sk": "Nechcem zeleninu.",
      "czph": "maj ao phak khrap"
    },
    {
      "th": "พ่อซักเสื้อผ้า",
      "cz": "Otec pere oblečení.",
      "sk": "Otec perie oblečenie.",
      "czph": "phó sak súa phá"
    },
    {
      "th": "อาหารร้านนี้อร่อย",
      "cz": "Jídlo v této restauraci je chutné.",
      "sk": "Jedlo v tejto reštaurácii je chutné.",
      "czph": "á hán rán ný arój"
    },
    {
      "th": "ปิดประตูห้องน้ำ",
      "cz": "Zavři dveře od koupelny.",
      "sk": "Zatvor dvere od kúpeľne.",
      "czph": "pit pona tú hóng nam"
    },
    {
      "th": "เช็คบิลด้วยครับ",
      "cz": "Účet, prosím.",
      "sk": "Účet, prosím.",
      "czph": "čék bin dúaj khrap"
    }
  ]
