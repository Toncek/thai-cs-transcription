  "sentences": [
    {
      "th": "ขอลองได้ไหมครับ",
      "cz": "Mohu si to vyzkoušet?",
      "sk": "Môžem si to vyskúšať?",
      "czph": "khó lóng daj maj khrap"
    },
    {
      "th": "ไซส์เล็กเกินไป",
      "cz": "Velikost je příliš malá.",
      "sk": "Veľkosť je príliš malá.",
      "czph": "saj lek kön paj"
    },
    {
      "th": "มีไซส์ใหญ่ไหม",
      "cz": "Máte velkou velikost?",
      "sk": "Máte veľkú veľkosť?",
      "czph": "mí saj jaj maj"
    },
    {
      "th": "แพงไป ลดหน่อยได้ไหม",
      "cz": "Je to moc drahé. Můžete trochu zlevnit?",
      "sk": "Je to moc drahé. Môžete trochu zľaviť?",
      "czph": "phéng paj lot nój daj maj"
    },
    {
      "th": "จ่ายเงินสดครับ",
      "cz": "Zaplatím v hotovosti.",
      "sk": "Zaplatím v hotovosti.",
      "czph": "džáj ngén sot khrap"
    },
    {
      "th": "รับบัตรเครดิตไหม",
      "cz": "Přijímáte kreditní karty?",
      "sk": "Prijímate kreditné karty?",
      "czph": "rap bat khrédyt maj"
    },
    {
      "th": "เสื้อนี้พอดี",
      "cz": "Toto tričko mi padne.",
      "sk": "Toto tričko mi sedí.",
      "czph": "súa ný phó dý"
    },
    {
      "th": "คุณอยากได้กี่ชิ้น",
      "cz": "Kolik kusů chcete?",
      "sk": "Koľko kusov chcete?",
      "czph": "khun ják daj kí čin"
    },
    {
      "th": "ขอสลิปด้วยค่ะ",
      "cz": "Účtenku, prosím.",
      "sk": "Účtenku, prosím.",
      "czph": "khó sa lyp dúaj kha"
    },
    {
      "th": "ฉันอยากเปลี่ยนสี",
      "cz": "Chci vyměnit barvu.",
      "sk": "Chcem vymeniť farbu.",
      "czph": "čan ják pélíjn sí"
    }
