  "sentences": [
    {
      "th": "ฉันอยากซื้อตั๋วรถไฟ",
      "cz": "Chci koupit jízdenku na vlak.",
      "sk": "Chcem kúpiť lístok na vlak.",
      "czph": "čan ják sú tua rot faj"
    },
    {
      "th": "รถไฟออกตอนไหน",
      "cz": "Kdy odjíždí vlak?",
      "sk": "Kedy odchádza vlak?",
      "czph": "rot faj aok tón naj"
    },
    {
      "th": "เที่ยวบินตรงเวลา",
      "cz": "Let je na čas.",
      "sk": "Let je na čas.",
      "czph": "thiau bin trong velá"
    },
    {
      "th": "ถึงสนามบินแล้ว",
      "cz": "Už jsme dorazili na letiště.",
      "sk": "Už sme dorazili na letisko.",
      "czph": "thúng sanám bin léu"
    },
    {
      "th": "จองที่นั่งได้ไหม",
      "cz": "Můžu si rezervovat sedadlo?",
      "sk": "Môžem si rezervovať sedadlo?",
      "czph": "džóng thý nang daj maj"
    },
    {
      "th": "กระเป๋าเดินทางของผม",
      "cz": "Moje zavazadlo.",
      "sk": "Moja batožina.",
      "czph": "kona pao dön tháng khóng phom"
    },
    {
      "th": "ขอดูพาสปอร์ตหน่อย",
      "cz": "Ukažte mi svůj pas.",
      "sk": "Ukážte mi svoj pas.",
      "czph": "khó dú páspórt nój"
    },
    {
      "th": "รถไฟมาช้า",
      "cz": "Vlak má zpoždění.",
      "sk": "Vlak mešká.",
      "czph": "rot faj má čá"
    },
    {
      "th": "ทางออกอยู่ไหน",
      "cz": "Kde je východ?",
      "sk": "Kde je východ?",
      "czph": "tháng aok jú naj"
    },
    {
      "th": "คุณมีแผนที่ไหม",
      "cz": "Máte mapu?",
      "sk": "Máte mapu?",
      "czph": "khun mí phén thý maj"
    }
  ]
