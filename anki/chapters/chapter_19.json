  "sentences": [
    {
      "th": "แมวอยู่ใต้โต๊ะ",
      "cz": "Kočka je pod stolem.",
      "sk": "Mačka je pod stolom.",
      "czph": "maéu jú táj to"
    },
    {
      "th": "หมาอยู่หน้าบ้าน",
      "cz": "Pes je před domem.",
      "sk": "Pes je pred domom.",
      "czph": "má jú ná bán"
    },
    {
      "th": "ผมไปบ่อยๆ",
      "cz": "Chodím tam často.",
      "sk": "Chodím tam často.",
      "czph": "phom paj bój bój"
    },
    {
      "th": "ฉันไม่เคยไป",
      "cz": "Nikdy jsem tam nebyla.",
      "sk": "Nikdy som tam nebola.",
      "czph": "čan maj khoéj paj"
    },
    {
      "th": "เราไปด้วยกัน",
      "cz": "Půjdeme spolu.",
      "sk": "Pôjdeme spolu.",
      "czph": "rao paj dúaj kan"
    },
    {
      "th": "เขาอยู่คนเดียว",
      "cz": "On je sám.",
      "sk": "On je sám.",
      "czph": "khau jú khon dyau"
    },
    {
      "th": "กินข้าวก่อน",
      "cz": "Sněz jídlo nejdříve.",
      "sk": "Zjedz jedlo najskôr.",
      "czph": "kin kháu kón"
    },
    {
      "th": "ยังไม่ได้กิน",
      "cz": "Ještě jsem nejedl.",
      "sk": "Ešte som nejedol.",
      "czph": "jang maj daj kin"
    },
    {
      "th": "ไปเดี๋ยวนี้",
      "cz": "Jdi hned teď.",
      "sk": "Choď hneď teraz.",
      "czph": "paj dyau ný"
    },
    {
      "th": "เขานอนแล้ว",
      "cz": "On už spí.",
      "sk": "On už spí.",
      "czph": "khau nón léu"
    }
