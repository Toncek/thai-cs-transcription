    {
      "th": "เมืองนี้ใหญ่มาก",
      "cz": "Toto město je velmi velké.",
      "sk": "Toto mesto je veľmi veľké.",
      "czph": "múang ný jaj mák"
    },
    {
      "th": "โรงแรมอยู่ใกล้สถานีรถไฟ",
      "cz": "Hotel je blízko vlakového nádraží.",
      "sk": "Hotel je blízko vlakovej stanice.",
      "czph": "róng rém jú klaj (vyslov klesající tón) satháný rot faj"
    },
    {
      "th": "ขอซื้อตั๋วครับ",
      "cz": "Rád bych koupil jízdenku.",
      "sk": "Rád by som kúpil lístok.",
      "czph": "khó sú tua khrap"
    },
    {
      "th": "จ่ายด้วยบัตรเครดิต",
      "cz": "Platit kreditní kartou.",
      "sk": "Platiť kreditnou kartou.",
      "czph": "džáj dúaj bat khrédyt"
    },
    {
      "th": "ขอลองไซส์ใหญ่",
      "cz": "Mohu zkusit větší velikost?",
      "sk": "Môžem skúsiť väčšiu veľkosť?",
      "czph": "khó lóng saj jaj"
    },
    {
      "th": "ฉันไม่เคยไปเมืองนี้",
      "cz": "Nikdy jsem v tomto městě nebyla.",
      "sk": "Nikdy som v tomto meste nebola.",
      "czph": "čan maj khoéj paj múang ný"
    },
    {
      "th": "เราเดินทางด้วยกัน",
      "cz": "Cestujeme spolu.",
      "sk": "Cestujeme spolu.",
      "czph": "rao dön tháng dúaj kan"
    },
    {
      "th": "รถไฟออกเร็ว",
      "cz": "Vlak odjíždí rychle.",
      "sk": "Vlak odchádza rýchlo.",
      "czph": "rot faj aok reu"
    },
    {
      "th": "แผนที่อยู่ในกระเป๋า",
      "cz": "Mapa je v tašce.",
      "sk": "Mapa je v taške.",
